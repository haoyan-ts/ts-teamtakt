# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://teamtakt:password@localhost:5432/teamtakt

# ── App security ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-use-strong-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Microsoft Azure / SSO ─────────────────────────────────────────────────────
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
AZURE_MS365_RECONNECT_REDIRECT_URI=http://localhost:8000/api/v1/auth/ms365/reconnect/callback

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Admin account ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
# Required in non-local environments. Min 12 chars, mixed case + digits + symbols.
ADMIN_PASSWORD=

# ── LLM (Azure OpenAI) ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://your-azure-openai.openai.azure.com/

# ── GitHub integration ────────────────────────────────────────────────────────
# Personal access token or GitHub App token used as fallback for autofill
GITHUB_TOKEN=

# GitHub OAuth app — for per-user account linking (profile settings)
# Register your OAuth app at: https://github.com/settings/developers
# Callback URL to register: http://localhost:8000/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# AES-256-GCM key for encrypting stored GitHub tokens (32 bytes = 64 hex chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_TOKEN_ENCRYPTION_KEY=
